{% extends 'base.html.twig' %}

{% block title %}Liste des sous-catégorie
{% endblock %}

{% block body %}
	<div class="container">
		<h1>Listes de sous catégories</h1>

		<table class="table">
			<thead>
				<tr>
					<th>Nom</th>
					<th>Catégorie</th>
					<th>Actions</th>
				</tr>
			</thead>
			<tbody>
				{% for sub_category in sub_categories %}
					<tr>
						<td>{{ sub_category.name }}</td>
						<td>{{ sub_category.category.name }}</td>
						<td>
							<a class="btn btn-outline-info" href="{{ path('app_sub_category_show', {'id': sub_category.id}) }}">Voir</a>
							<a class="btn btn-outline-warning" href="{{ path('app_sub_category_edit', {'id': sub_category.id}) }}">Modifier</a>
							<a  class="btn btn-danger" href="{{ path('app_sub_category_delete', {'id': sub_category.id}) }}">Supprimer</a>
						</td>
					</tr>
				{% else %}
					<tr>
						<td colspan="3">Rien trouvé</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>

		<a class="btn btn-outline-primary" href="{{ path('app_sub_category_new') }}">Créer une nouvelle sous-catégorie</a>
	</div>
{% endblock %}
